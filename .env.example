# ============================================================
# MedTrack AI — Firebase Configuration
# ============================================================
# INSTRUCTIONS:
#   1. Go to https://console.firebase.google.com
#   2. Create a project (or open existing)
#   3. Project Settings → General → Your Apps → Web App (</> icon)
#   4. Register your app, copy the firebaseConfig object values below
#   5. Copy this file to .env and replace every value
#   6. Enable Authentication: Email/Password + Google (Auth → Sign-in method)
#   7. Enable Firestore: Firestore Database → Create database (Start in test mode)
# ============================================================

VITE_FIREBASE_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456
